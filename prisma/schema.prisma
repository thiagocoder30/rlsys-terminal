generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id               String   @id @default(uuid())
  initial_bankroll Float
  current_bankroll Float
  status           String   @default("ACTIVE") // Controla se a mesa está rodando
  closed_at        DateTime?                   // Registra o segundo exato do saque final
  created_at       DateTime @default(now())
  spins            Spin[]
  signals          Signal[]
}

model Spin {
  id         String   @id @default(uuid())
  session_id String
  number     Int
  color      String
  parity     String
  dozen      String
  column     String
  half       String
  created_at DateTime @default(now())
  session    Session  @relation(fields: [session_id], references: [id])
}

model Strategy {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?  // Opcional para não quebrar o Bootstrapper
  bayes_weight Float    @default(1.0) // Restaurado o peso matemático
  is_active    Boolean  @default(true)
  signals      Signal[]
}

model Signal {
  id               String   @id @default(uuid())
  session_id       String
  strategy_id      String
  target_bet       String
  suggested_amount Float
  result           String   @default("PENDING")
  created_at       DateTime @default(now())
  session          Session  @relation(fields: [session_id], references: [id])
  strategy         Strategy @relation(fields: [strategy_id], references: [id])
}
